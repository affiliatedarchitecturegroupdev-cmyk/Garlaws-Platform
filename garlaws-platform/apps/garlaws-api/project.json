{
  "name": "garlaws-api",
  "$schema": "./node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/garlaws-api/src",
  "prefix": "garlaws",
  "targets": {
    "build": {
      "executor": "@nx/js:node",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/garlaws-api",
        "main": "apps/garlaws-api/src/main.ts",
        "tsConfig": "apps/garlaws-api/tsconfig.app.json",
        "assets": ["apps/garlaws-api/src/assets"]
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "garlaws-api:build"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/garlaws-api/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  },
  "tags": ["scope:api", "type:app"]
}